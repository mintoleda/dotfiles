{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "openrouter": {
            "api": "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"
        },
        "google": {
            "api": "AIzaSyBhOdDsrgA5ObRTbR0te-mH__UaIxs1Y-c"
        }
    },
    "model": "google/gemini-3.1-pro-preview",
    "small_model": "google/gemini-3.1-flash-lite-preview",
    "agent": {
        "plan": {
            "mode": "primary",
            "model": "openrouter/qwen/qwen3.6-plus:free",
            "description": "78.8% SWE-bench, 1M context, free — infinite planning iterations",
            "permission": {
                "write": "deny",
                "edit": "deny",
                "bash": "deny"
            }
        },

        "build": {
            "mode": "primary",
            "model": "google/gemini-3-flash-preview",
            "description": "80.6% SWE-bench, best for code generation"
        },

        "ask": {
            "description": "Quick Q&A agent, read-only, free model",
            "mode": "primary",
            "model": "google/gemini-3.1-flash-lite-preview",
            "permission": {
                "write": "deny",
                "edit": "deny",
                "bash": "deny"
            }
        },
        
        "code-reviewer": {
            "description": "Near-frontier intelligence at zero cost",
            "mode": "subagent",
            "model": "openrouter/qwen/qwen3.6-plus:free",
            "permission": {
                "write": "deny",
                "edit": "ask"
            }
        },
        "debug": {
            "description": "Fast, cheap, top open-source on SWE-bench, good at log parsing",
            "mode": "subagent",
            "model": "openrouter/xiaomi/mimo-v2-flash",
            "permission": {
                "bash": "allow",
                "edit": "ask"
            }
        },
        "explore": {
            "description": "1500 free daily requests via Google API, zero OpenRouter credits",
            "mode": "subagent",
            "model": "google/gemini-3.1-flash-lite-preview"
        },
        
    },
}
