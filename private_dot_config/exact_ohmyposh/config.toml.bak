console_title_template = '{{ .Shell }} in {{ .Folder }}'
version = 4
final_space = true

[[blocks]]
  type = 'prompt'
  alignment = 'left'

  [[blocks.segments]]
    type = 'path'
    style = 'plain'
    background = 'transparent'
    foreground = 'green'

    [blocks.segments.properties]
      style = 'full'

  [[blocks.segments]]
    type = 'text'
    style = 'plain'
    foreground = 'magenta'
    background = 'transparent'
    template = "{{ .Folder }} >"
