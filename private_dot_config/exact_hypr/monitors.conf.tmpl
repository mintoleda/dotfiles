{{- if eq .chezmoi.hostname "prometheus" -}}
# Laptop: internal display
monitor=eDP-2,2880x1620@120.0,0x0,2.0
{{- else if eq .chezmoi.hostname "daedalus" -}}
# Desktop: external monitor on DP-2
monitor=DP-2,preferred,auto,1
{{- else -}}
# Fallback: auto-detect
monitor=,preferred,auto,auto
{{- end -}}